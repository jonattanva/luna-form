{
    "sections": [
        {
            "compact": true,
            "fields": [
                {
                    "type": "column",
                    "advanced": {
                        "cols": 3
                    },
                    "fields": [
                        {
                            "advanced": {
                                "cols": 2
                            },
                            "label": "Label",
                            "name": "label",
                            "type": "input/text",
                            "required": true,
                            "validation": {
                                "required": "Label is required"
                            }
                        },
                        {
                            "advanced": {
                                "cols": 1
                            },
                            "label": "Type",
                            "name": "type",
                            "type": "select",
                            "source": [
                                {
                                    "label": "Text",
                                    "value": "input/text"
                                },
                                {
                                    "label": "Email",
                                    "value": "input/email"
                                },
                                {
                                    "label": "Number",
                                    "value": "input/number"
                                },
                                {
                                    "label": "Password",
                                    "value": "input/password"
                                },
                                {
                                    "label": "Date",
                                    "value": "input/date"
                                },
                                {
                                    "label": "Textarea",
                                    "value": "textarea"
                                },
                                {
                                    "label": "Select",
                                    "value": "select"
                                },
                                {
                                    "label": "Radio",
                                    "value": "radio"
                                },
                                {
                                    "label": "Checkbox",
                                    "value": "checkbox"
                                },
                                {
                                    "label": "Switch",
                                    "value": "checkbox/switch"
                                }
                            ],
                            "required": true,
                            "validation": {
                                "required": "Type is required"
                            },
                            "event": {
                                "change": [
                                    {
                                        "action": "state",
                                        "target": [
                                            "advanced.preselected",
                                            "advanced.sourceType"
                                        ],
                                        "state": {
                                            "hidden": false
                                        },
                                        "when": [
                                            "radio",
                                            "select"
                                        ]
                                    },
                                    {
                                        "action": "state",
                                        "target": "advanced.reverse",
                                        "state": {
                                            "hidden": false
                                        },
                                        "when": [
                                            "radio",
                                            "checkbox",
                                            "checkbox/switch"
                                        ]
                                    },
                                    {
                                        "action": "state",
                                        "target": "validation.email",
                                        "state": {
                                            "hidden": false
                                        },
                                        "when": "input/email"
                                    },
                                    {
                                        "action": "state",
                                        "target": [
                                            "advanced.length.max",
                                            "advanced.length.min",
                                            "validation.length.max",
                                            "validation.length.min"
                                        ],
                                        "state": {
                                            "hidden": false
                                        },
                                        "when": [
                                            "input/email",
                                            "input/number",
                                            "input/password",
                                            "input/text",
                                            "textarea"
                                        ]
                                    },
                                    {
                                        "action": "state",
                                        "target": "advanced.autocomplete",
                                        "state": {
                                            "hidden": false
                                        },
                                        "when": [
                                            "input/email",
                                            "input/number",
                                            "input/password",
                                            "input/text",
                                            "select",
                                            "textarea"
                                        ]
                                    }
                                ]
                            }
                        }
                    ]
                },
                {
                    "label": "Placeholder",
                    "name": "placeholder",
                    "type": "input/text"
                },
                {
                    "label": "Help text",
                    "name": "description",
                    "type": "textarea"
                },
                {
                    "advanced": {
                        "reverse": false
                    },
                    "label": "Mandatory field",
                    "name": "required",
                    "type": "checkbox/switch",
                    "description": "Users must fill this to submit the form",
                    "event": {
                        "change": [
                            {
                                "action": "state",
                                "target": "validation.required",
                                "state": {
                                    "hidden": false
                                },
                                "when": true
                            }
                        ]
                    }
                },
                {
                    "advanced": {
                        "reverse": false
                    },
                    "label": "View only",
                    "name": "readonly",
                    "type": "checkbox/switch",
                    "description": "Prevent users from editing this value"
                }
            ]
        },
        {
            "title": "Source",
            "compact": true,
            "advanced": true,
            "fields": [
                {
                    "label": "Get options from",
                    "name": "advanced.sourceType",
                    "type": "select",
                    "source": [
                        {
                            "label": "Static",
                            "value": "static"
                        },
                        {
                            "label": "Dynamic (API)",
                            "value": "dynamic"
                        }
                    ],
                    "description": "Choose how you want to provide the choices for this field",
                    "event": {
                        "change": [
                            {
                                "action": "state",
                                "target": "source",
                                "state": {
                                    "hidden": false
                                },
                                "when": "static"
                            },
                            {
                                "action": "state",
                                "target": [
                                    "advanced.options.label",
                                    "advanced.options.value",
                                    "advanced.sourceHeaders",
                                    "advanced.sourceMethod",
                                    "advanced.sourceNamespace",
                                    "advanced.sourceUrl"
                                ],
                                "state": {
                                    "hidden": false
                                },
                                "when": "dynamic"
                            }
                        ]
                    },
                    "required": true,
                    "hidden": true
                },
                {
                    "label": "Options",
                    "name": "source",
                    "type": "list",
                    "description": "Create the list of choices that will appear in the selector",
                    "fields": [
                        {
                            "advanced": {
                                "cols": 2
                            },
                            "type": "column",
                            "fields": [
                                {
                                    "label": "Option name (Label)",
                                    "name": "label",
                                    "type": "input/text",
                                    "placeholder": "e.g., Option 1",
                                    "required": true
                                },
                                {
                                    "label": "Option code (Value)",
                                    "name": "value",
                                    "type": "input/text",
                                    "placeholder": "e.g., option_1",
                                    "required": true
                                }
                            ]
                        }
                    ],
                    "hidden": true
                },
                {
                    "label": "Connection method",
                    "name": "advanced.sourceMethod",
                    "type": "select",
                    "source": [
                        {
                            "label": "GET",
                            "value": "GET"
                        },
                        {
                            "label": "POST",
                            "value": "POST"
                        }
                    ],
                    "description": "How should we ask for the information?",
                    "hidden": true
                },
                {
                    "label": "Link or Address (URL)",
                    "name": "advanced.sourceUrl",
                    "type": "input/text",
                    "description": "Paste the web address to your list of options",
                    "hidden": true
                },
                {
                    "label": "List location (Path)",
                    "name": "advanced.sourceNamespace",
                    "type": "input/text",
                    "description": "Where is the list inside the data? (e.g., 'results')",
                    "hidden": true
                },
                {
                    "advanced": {
                        "cols": 2
                    },
                    "type": "column",
                    "fields": [
                        {
                            "label": "Display text (Label)",
                            "name": "advanced.options.label",
                            "type": "input/text",
                            "placeholder": "e.g., name",
                            "description": "Which field has the name users will see?",
                            "hidden": true
                        },
                        {
                            "label": "Unique ID (Primary Key)",
                            "name": "advanced.options.value",
                            "type": "input/text",
                            "placeholder": "e.g., id",
                            "description": "Which field identifies each item? (e.g., 'id' or 'code').",
                            "hidden": true
                        }
                    ]
                },
                {
                    "label": "Access keys (Headers)",
                    "name": "advanced.sourceHeaders",
                    "type": "list",
                    "description": "Special keys or passwords needed to reach your data",
                    "fields": [
                        {
                            "label": "Setting name",
                            "name": "key",
                            "type": "input/text",
                            "placeholder": "Authorization"
                        },
                        {
                            "label": "Setting value",
                            "name": "value",
                            "type": "input/text",
                            "placeholder": "Your secret key or password"
                        }
                    ],
                    "hidden": true
                }
            ]
        },
        {
            "title": "Advanced options",
            "compact": true,
            "advanced": true,
            "fields": [
                {
                    "label": "Name",
                    "name": "name",
                    "type": "input/text",
                    "description": "Unique identifier for form data",
                    "required": true,
                    "validation": {
                        "required": "Name is required"
                    }
                },
                {
                    "label": "Default value",
                    "name": "value",
                    "type": "input/text",
                    "description": "Initial value for the field"
                },
                {
                    "label": "Autocomplete",
                    "name": "advanced.autocomplete",
                    "type": "select",
                    "source": [
                        {
                            "label": "Off",
