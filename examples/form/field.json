                        },
                        {
                            "label": "Current password",
                            "value": "current-password"
                        },
                        {
                            "label": "New password",
                            "value": "new-password"
                        },
                        {
                            "label": "One-time code",
                            "value": "one-time-code"
                        },
                        {
                            "label": "Organization",
                            "value": "organization"
                        },
                        {
                            "label": "Organization title",
                            "value": "organization-title"
                        },
                        {
                            "label": "Street address",
                            "value": "street-address"
                        },
                        {
                            "label": "Address line 1",
                            "value": "address-line1"
                        },
                        {
                            "label": "Address line 2",
                            "value": "address-line2"
                        },
                        {
                            "label": "Address line 3",
                            "value": "address-line3"
                        },
                        {
                            "label": "City",
                            "value": "address-level2"
                        },
                        {
                            "label": "State/Province",
                            "value": "address-level1"
                        },
                        {
                            "label": "Country code",
                            "value": "country"
                        },
                        {
                            "label": "Country name",
                            "value": "country-name"
                        },
                        {
                            "label": "Postal code",
                            "value": "postal-code"
                        },
                        {
                            "label": "Credit card name",
                            "value": "cc-name"
                        },
                        {
                            "label": "Credit card number",
                            "value": "cc-number"
                        },
                        {
                            "label": "Credit card expiry",
                            "value": "cc-exp"
                        },
                        {
                            "label": "Credit card month",
                            "value": "cc-exp-month"
                        },
                        {
                            "label": "Credit card year",
                            "value": "cc-exp-year"
                        },
                        {
                            "label": "Credit card security code",
                            "value": "cc-csc"
                        },
                        {
                            "label": "Credit card type",
                            "value": "cc-type"
                        },
                        {
                            "label": "Transaction currency",
                            "value": "transaction-currency"
                        },
                        {
                            "label": "Transaction amount",
                            "value": "transaction-amount"
                        },
                        {
                            "label": "Language",
                            "value": "language"
                        },
                        {
                            "label": "Birthday",
                            "value": "bday"
                        },
                        {
                            "label": "Gender",
                            "value": "sex"
                        },
                        {
                            "label": "URL",
                            "value": "url"
                        },
                        {
                            "label": "Photo",
                            "value": "photo"
                        },
                        {
                            "label": "Telephone",
                            "value": "tel"
                        }
                    ],
                    "description": "Browser autocomplete behavior",
                    "hidden": true
                },
                {
                    "label": "Orientation",
                    "name": "orientation",
                    "type": "select",
                    "source": [
                        {
                            "label": "Horizontal",
                            "value": "horizontal"
                        },
                        {
                            "label": "Vertical",
                            "value": "vertical"
                        }
                    ],
                    "description": "Orientation of the field"
                },
                {
                    "advanced": {
                        "reverse": false
                    },
                    "label": "Hidden",
                    "name": "hidden",
                    "type": "checkbox/switch",
                    "description": "Whether the field is hidden"
                },
                {
                    "advanced": {
                        "reverse": false
                    },
                    "label": "Reverse",
                    "name": "advanced.reverse",
                    "type": "checkbox/switch",
                    "description": "Whether the field is reversed",
                    "hidden": true
                },
                {
                    "advanced": {
                        "reverse": false
                    },
                    "label": "Preselected",
                    "name": "advanced.preselected",
                    "type": "checkbox/switch",
                    "description": "Whether the field is preselected",
                    "hidden": true
                }
            ]
        },
        {
            "title": "Validation rules",
            "compact": true,
            "advanced": true,
            "fields": [
                {
                    "label": "Required error",
                    "name": "validation.required",
                    "type": "input/text",
                    "description": "Message shown when the field is empty.",
                    "placeholder": "This field is required",
                    "hidden": true
                },
                {
                    "label": "Invalid email error",
                    "name": "validation.email",
                    "type": "input/text",
                    "description": "Message shown for incorrect email formats.",
                    "placeholder": "Please enter a valid email address",
                    "hidden": true
                },
                {
                    "label": "Min length",
                    "name": "advanced.length.min",
                    "type": "input/number",
                    "description": "Minimum number of characters required",
                    "hidden": true
                },
                {
                    "label": "Min length error",
                    "name": "validation.length.min",
                    "type": "input/text",
                    "description": "Shown if the input is too short.",
                    "placeholder": "Must be at least {min} characters",
                    "hidden": true
                },
                {
                    "label": "Max length",
                    "name": "advanced.length.max",
                    "type": "input/number",
                    "description": "Maximum number of characters allowed",
                    "hidden": true
                },
                {
                    "label": "Max length error",
                    "name": "validation.length.max",
                    "type": "input/text",
                    "description": "Shown if the input is too long.",
                    "placeholder": "Must be at most {max} characters",
                    "hidden": true
                }
            ]
        },
        {
            "title": "Developer",
            "compact": true,
            "advanced": true,
            "fields": [
                {
                    "advanced": {
                        "action": "Add attribute"
                    },
                    "label": "Data attributes",
                    "description": "Add custom data-attributes for scripts or tracking (e.g., data-test-id)",
                    "name": "advanced.data",
                    "type": "list",
                    "fields": [
                        {
                            "name": "key",
                            "label": "Key",
                            "type": "input/text",
                            "placeholder": "data-tracking"
                        },
                        {
                            "name": "value",
                            "label": "Value",
                            "type": "input/text",
                            "placeholder": "custom_value"
                        }
                    ]
                },
                {
                    "advanced": {
                        "action": "Add attribute"
                    },
                    "label": "Aria attributes",
                    "description": "Improve accessibility by defining ARIA roles and properties (e.g., aria-label)",
                    "name": "advanced.aria",
                    "type": "list",
                    "fields": [
                        {
                            "name": "key",
                            "label": "Key",
                            "type": "input/text",
                            "placeholder": "aria-label"
                        },
                        {
                            "name": "value",
                            "label": "Value",
                            "type": "input/text",
                            "placeholder": "Close modal"
                        }
                    ]
                }
            ]
        }
    ]
}