{
  "advanced": { "step": true },
  "sections": [
    {
      "title": "Your webhook address",
      "description": "Share this address with the other application. Every time you send data here, this flow will run.",
      "fields": [
        {
          "label": "Webhook URL",
          "name": "webhook",
          "type": "input/text",
          "required": true,
          "readonly": true
        }
      ]
    },
    {
      "title": "What information should be included?",
      "description": "Define the data you expect to receive. If any field marked as required is missing, we will automatically reject the request.",
      "fields": [
        {
          "advanced": {
            "action": "Add another field",
            "collapsed": true,
            "preview": {
              "badge": {
                "when": { "field": "required", "operator": "eq", "value": "true" },
                "label": "Required"
              },
              "label": "label",
              "tags": ["type", "name"]
            },
            "length": { "min": 0 }
          },
          "name": "field",
          "type": "list",
          "fields": [
            {
              "advanced": { "cols": 3 },
              "type": "column",
              "fields": [
                {
                  "advanced": { "cols": 2 },
                  "label": "Name that users will see",
                  "name": "label",
                  "type": "input/text",
                  "event": {
                    "change": [
                      {
                        "action": "value",
                        "onlyIfTargetEmpty": true,
                        "value": { "field/name": "{value}" }
                      }
                    ]
                  },
                  "required": true
                },
                {
                  "advanced": { "cols": 1 },
                  "label": "Required?",
                  "name": "required",
                  "type": "select/active",
                  "required": true,
                  "defaultValue": false
