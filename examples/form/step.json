              "name": "type",
              "type": "chips",
              "source": [
                { "id": "text", "name": "Text", "description": "Names, notes, or any simple text" },
                { "id": "number", "name": "Number", "description": "Quantities, prices, or measures" },
                { "id": "email", "name": "Email", "description": "A standard email address" },
                { "id": "phone", "name": "Phone", "description": "Phone numbers with or without symbols" },
                { "id": "boolean", "name": "Boolean", "description": "Yes/No or True/False choices" },
                { "id": "date", "name": "Date", "description": "A specific calendar day or time" },
                { "id": "link", "name": "Link", "description": "A clickable website address" },
                { "id": "list", "name": "List / Collection", "description": "Groups of items or detailed records" }
              ],
              "event": {
                "change": [
                  {
                    "action": "state",
                    "target": "field/type_collection",
                    "state": { "hidden": false },
                    "when": ["list"]
                  }
                ]
              }
            },
            {
              "advanced": {
                "multiple": false,
                "options": { "description": "description", "label": "name", "value": "id" }
              },
              "label": "What kind of items are in this list?",
              "name": "type_collection",
              "type": "chips",
              "source": [
                { "id": "simpleList", "name": "Simple list", "description": "Just single pieces of information, like a list of names, numbers, or emails" },
                { "id": "detailedItems", "name": "Detailed items", "description": "Each item is a group of fields, like a \"Contact\" with its own name and phone number" }
              ],
              "required": true,
              "hidden": true,
              "event": {
                "change": [
                  {
                    "action": "state",
                    "target": "field/data_type",
                    "state": { "hidden": false },
                    "when": ["simpleList"]
                  },
                  {
                    "action": "state",
                    "target": "field/collection_type",
                    "state": { "hidden": false },
                    "when": ["detailedItems"]
