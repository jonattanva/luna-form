{
  "name": "luna-form",
  "description": "A monorepo for Luna, a form builder library based on JSON.",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "benchmark": "pnpm exec tsx benchmark/form-build.bench.ts",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "prepare": "husky",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "serve": "pnpm --filter react-luna-editor dev",
    "start": "pnpm --filter react-luna-editor start",
    "test:e2e": "pnpm playwright test --grep '@e2e'",
    "test:e2e:ui": "pnpm playwright test --grep '@e2e' --ui",
    "test:perf": "pnpm playwright test --grep '@perf' --project=chromium",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "typescript": "turbo run typescript"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@types/eslint-plugin-jsx-a11y": "6.10.1",
    "@types/node": "25.9.3",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "esbuild": "0.28.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-playwright": "2.10.4",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jotai": "2.20.1",
    "lint-staged": "17.0.7",
    "mitata": "1.0.34",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tsx": "4.22.4",
    "turbo": "2.9.18",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.9",
    "zod": "4.4.3"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonattanva/luna-form.git"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22.x",
    "pnpm": ">=11.x"
  }
}
