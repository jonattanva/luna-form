{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "./dist/types",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "..",
    "skipLibCheck": true,
    "strict": true,
    "stripInternal": true,
    "target": "es2020",
    "verbatimModuleSyntax": true,
    "paths": {
      "@luna-form/core": ["../luna-core/dist/types/index.d.ts"]
    }
  },
  "exclude": ["node_modules", "./dist/**/*"]
}
